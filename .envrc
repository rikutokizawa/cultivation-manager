# ~/.envrc (for Python projects)

# 1) mise の環境を有効化
eval "$(mise activate zsh --shims)"

# 2) mise 管理の Python を明示
export UV_PYTHON="$(mise which python)"

# 3) .venv がなければ作成
if [ ! -d ".venv" ]; then
  echo "[direnv] Creating .venv using: $UV_PYTHON"
  uv venv --python "$UV_PYTHON"
fi

# 4) 仮想環境を有効化
source .venv/bin/activate

export UV_PYTHON="$VIRTUAL_ENV/bin/python"