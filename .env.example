SENSOR_SOURCE_TYPE=dummy
CAMERA_SOURCE_TYPE=dummy
SENSOR_POLL_INTERVAL_SECONDS=300
IMAGE_CAPTURE_INTERVAL_SECONDS=900
CAMERA_IDS_CSV=camera-01,camera-02
RUNTIME_LOG_LEVEL=INFO
